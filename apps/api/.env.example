# Copy this file to .env and fill in your values.
# For local dev, use a Neon Postgres connection string (or a local Postgres instance).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mandai?sslmode=require"
PORT=3001

# CORS origin for the frontend. Defaults to "*" when unset (OK for local dev).
# REQUIRED in production — set to your Vercel frontend URL to avoid open CORS.
# Example: CORS_ORIGIN="https://mandai.vercel.app"
CORS_ORIGIN=
